# OpenAI API (서버사이드 전용 - VITE_ 접두사 사용 금지)
OPENAI_API_KEY=sk-proj-xxx

# 카카오 SDK (클라이언트용 - VITE_ 접두사 필수)
VITE_KAKAO_JS_KEY=your-kakao-js-key
VITE_SITE_URL=https://finance-fortune.vercel.app

# Upstash Redis (선택 - Rate Limiting + 캐시용)
# 설정하지 않으면 인메모리 폴백 사용 (프로덕션에서는 Redis 권장)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel CLI (Docker 개발 환경용)
VERCEL_TOKEN=
